# Mini-Bili 后端环境变量示例（复制为 .env 或在启动前 export）
# 必填
JWT_SECRET=change-me-in-production
MYSQL_DSN=user:password@tcp(127.0.0.1:3306)/minibili?charset=utf8mb4&parseTime=True&loc=Local

# HTTP
APP_ENV=development
HTTP_ADDR=:8080

# Redis（播放计数增量、弹幕冷却、全站热搜统计、Refresh Token 黑名单等）
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=20

# Elasticsearch（搜索页 /api/v1/search；为空则搜索返回 search_status=unavailable）
# 也支持 OpenSearch / Bonsai（HTTPS + 用户名密码；URL 勿含 @ 内嵌凭证）
# 启动后需对已有视频做索引（发布/更新会自动索引；可调用管理接口或脚本全量同步）
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# 敏感词（弹幕、评论、搜索热搜统计过滤；文件不存在则相关 UGC 会被拒绝）
SENSITIVE_WORDS_FILE=./configs/sensitive_words.txt

# 消息队列（视频转码等，可选）
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# 阿里云 OSS（视频/封面上传，可选）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_PUBLIC_URL_PREFIX=

# 其它
TEMP_UPLOAD_DIR=./data/tmp
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
IP2REGION_V4_XDB=./configs/ip2region_v4.xdb
# 从 https://github.com/lionsoul2014/ip2region 下载 ip2region_v4.xdb 放到 configs/（仓库 .gitignore 已排除）
IP2REGION_DEV_CLIENT_IP=

# 运营后台首个管理员（仅当 admins 表为空时创建一次，勿提交真实密码）
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-me-admin

# 视频审核：转码成功后进入 pending_review，运营通过后才会 published 并进入搜索（默认 true）
VIDEO_REVIEW_REQUIRED=true

# 专栏审核：投稿后进入 pending_review，运营通过后才会 published 并进入搜索（默认 true）
ARTICLE_REVIEW_REQUIRED=true

# 关闭网页端视频文件上传与转码（仍允许保存稿件元数据草稿；默认 false）
VIDEO_UPLOAD_DISABLED=false

# AI 助手（消息中心固定「Minibili AI」会话；DeepSeek OpenAI 兼容接口）
# 为空则仅创建助手会话，用户发消息后返回「未配置」提示
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AGENT_BOT_USERNAME=minibili_ai
AGENT_ENABLED=true
AGENT_MAX_HISTORY=20
AGENT_HISTORY_TTL=720h
AGENT_DAILY_QUOTA=80
AGENT_REQUEST_TIMEOUT=90s


# Global rate limiting (Redis token bucket, disabled by default; per-IP limiting for public API protection)
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_RATE=20
# RATE_LIMIT_BURST=50
