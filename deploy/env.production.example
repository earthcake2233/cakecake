# /opt/minibili/.env — 生产环境示例（复制后修改，勿提交仓库）

APP_ENV=production
HTTP_ADDR=127.0.0.1:8080

JWT_SECRET=请替换为长随机串

MYSQL_DSN=minibili:请替换@tcp(127.0.0.1:3306)/minibili?charset=utf8mb4&parseTime=True&loc=Local

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# 腾讯云 ES Serverless（HTTPS + 白名单放行本机 ECS 公网 IP）
ELASTICSEARCH_URL=https://你的实例.es.tencentcloud.com:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=请替换

SENSITIVE_WORDS_FILE=./configs/sensitive_words.txt
TEMP_UPLOAD_DIR=./data/tmp
FFPROBE_PATH=/usr/bin/ffprobe
FFMPEG_PATH=/usr/bin/ffmpeg
IP2REGION_V4_XDB=./configs/ip2region_v4.xdb

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_PUBLIC_URL_PREFIX=

ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=请替换-仅首次建库生效

VIDEO_REVIEW_REQUIRED=true
ARTICLE_REVIEW_REQUIRED=true

# 关闭网页端视频文件上传与转码（仍允许保存稿件元数据草稿）
VIDEO_UPLOAD_DISABLED=true

# AI 助手（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AGENT_BOT_USERNAME=minibili_ai
AGENT_ENABLED=true
AGENT_MAX_HISTORY=20
AGENT_HISTORY_TTL=720h
AGENT_DAILY_QUOTA=80
AGENT_REQUEST_TIMEOUT=90s
