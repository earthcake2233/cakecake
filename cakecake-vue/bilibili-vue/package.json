{
  "name": "cakecake-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,vue,ts}\"",
    "check:encoding": "node scripts/check-encoding.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dompurify": "^3.4.5",
    "element-plus": "^2.9.4",
    "markdown-it": "^14.1.1",
    "vue": "^3.5.13",
    "vue-lazyload": "^3.0.0-rc.2",
    "vue-router": "^4.5.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^9.4.3"
  },
  "eslintConfig": {
    "root": true,
    "parser": "vue-eslint-parser",
    "env": {
      "node": true,
      "browser": true,
      "es2022": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:vue/vue3-essential",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "generator-star-spacing": "off",
      "no-tabs": 0,
      "indent": 0,
      "eol-last": 0,
      "space-before-function-paren": [
        0,
        "always"
      ],
      "space-in-parens": [
        0,
        "never"
      ],
      "eqeqeq": "off",
      "no-unneeded-ternary": 0,
      "no-unused-expressions": 0,
      "vue/no-v-for-template-key-on-child": "off",
      "vue/no-unused-vars": "off",
      "vue/no-v-model-argument": "off",
      "vue/multi-word-component-names": "off",
      "vue/no-side-effects-in-computed-properties": "off",
      "vue/no-parsing-error": [
        2,
        {
          "x-invalid-end-tag": false
        }
      ],
      "no-useless-escape": "off",
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    },
    "overrides": [
      {
        "files": [
          "*.ts",
          "**/*.ts"
        ],
        "parser": "@typescript-eslint/parser",
        "plugins": [
          "@typescript-eslint"
        ],
        "parserOptions": {
          "ecmaVersion": "latest",
          "sourceType": "module"
        },
        "rules": {
          "no-unused-vars": "off",
          "@typescript-eslint/no-unused-vars": [
            "warn",
            {
              "argsIgnorePattern": "^_"
            }
          ]
        }
      }
    ]
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
