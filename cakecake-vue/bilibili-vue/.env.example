# ========== 前端 (Vite) ==========

# 设为 true 时使用远程 axios 接口（旧 B 站 mock 域名）
VITE_USE_REMOTE_API=false

# 设为 true 时对接 Mini-Bili Go 后端（/api/v1、登录、评论、弹幕 WebSocket 等）
VITE_MINIBILI_API=true

# API 根地址（无尾部斜杠）。不填时走 Vite 代理到 http://127.0.0.1:8080（见 vite.config.js）
# VITE_REMOTE_API_BASE=http://127.0.0.1:8080

# ========== 后端需单独配置（见仓库根目录 .env.example）==========
#
# Elasticsearch（搜索）
#   ELASTICSEARCH_URL=http://127.0.0.1:9200
#   ELASTICSEARCH_USERNAME=
#   ELASTICSEARCH_PASSWORD=
# 未配置时搜索页显示「搜索服务未就绪」空状态图。
#
# Redis（全站热搜、播放计数、弹幕冷却等）
#   REDIS_ADDR=127.0.0.1:6379
#
# 敏感词（UGC + 热搜统计）
#   SENSITIVE_WORDS_FILE=./configs/sensitive_words.txt
#
# MySQL / JWT / OSS 等见根目录 .env.example
