# 生产构建用（npm run build 前复制为 .env.production）
# 在服务器上由 Nginx 反代 /api，不要设置 VITE_REMOTE_API_BASE

VITE_MINIBILI_API=true
VITE_USE_REMOTE_API=false

# 演示服务器资源不足时可关闭网页端视频文件上传（仍可保存稿件元数据到服务端）
VITE_VIDEO_UPLOAD_DISABLED=true
# VITE_VIDEO_UPLOAD_DISABLED_TITLE=视频文件需线下处理
# VITE_VIDEO_UPLOAD_DISABLED_MESSAGE=当前服务器暂不支持网页上传与转码视频。你仍可填写标题、简介、分区、标签和封面并保存；视频 MP4 将由管理员本地处理后关联。
